# ── Aeolus Environment Configuration ─────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Mistral API (primary LLM provider) ───────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Agent Identity ────────────────────────────────────────────────────────────
# Name of this agent (e.g., agent-alpha, agent-beta, agent-gamma)
AGENT_NAME=agent-alpha

# Comma-separated list of capabilities this agent specialises in
AGENT_CAPABILITIES=text summarisation,sentiment analysis,question answering

# Model tier: 3B (fast/cheap), 8B (balanced), LARGE (powerful)
MODEL_TIER=3B

# Max concurrent tasks this agent will accept
MAX_CONCURRENT_TASKS=2

# ── LLM Model Overrides (optional) ───────────────────────────────────────────
TIER1_MODEL=ministral-3b-latest
TIER2_MODEL=ministral-8b-latest
TIER3_MODEL=mistral-large-latest

# ── Ollama Fallback (set LOCAL_ONLY=true to skip Mistral API entirely) ────────
LOCAL_ONLY=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=ministral:3b

# ── NATS Transport ────────────────────────────────────────────────────────────
# Install NATS server: https://nats.io/download/
# Run locally: nats-server (or use Docker: docker run -p 4222:4222 nats)
NATS_URL=nats://localhost:4222

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8501

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
